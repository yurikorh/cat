DRIVER=~fastapi+~websockets
HOST=0.0.0.0
PORT=8080

# ═══════════════════════════════════════════════════
#  机器人身份
# ═══════════════════════════════════════════════════
BOT_QQ=你的机器人QQ号
MASTER_QQ=主人QQ号
MASTER_NAME=主人昵称

DATA_DIR=data
PERSONA_PATH=personas/default.yaml

# ═══════════════════════════════════════════════════
#  LLM 配置 — 每个任务可独立指向本地或云端
#
#  格式：{前缀}_API_KEY / {前缀}_BASE_URL / {前缀}_MODEL
#  前缀：LLM_CHAT（对话）、LLM_TRIGGER（触发）、LLM_MEMORY（记忆）
#
#  下面提供两套 profile，取消注释你需要的那套即可。
# ═══════════════════════════════════════════════════

# ─── Profile A: 2080 Ti 22GB（推荐正式环境） ───
#  对话走云端 API，触发和记忆走本地 Ollama
# LLM_CHAT_API_KEY=your_qwen_api_key_here
# LLM_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_CHAT_MODEL=qwen-plus

# LLM_TRIGGER_API_KEY=ollama
# LLM_TRIGGER_BASE_URL=http://localhost:11434/v1
# LLM_TRIGGER_MODEL=qwen2.5:7b

# LLM_MEMORY_API_KEY=ollama
# LLM_MEMORY_BASE_URL=http://localhost:11434/v1
# LLM_MEMORY_MODEL=qwen2.5:14b

# ─── Profile B: 纯 API（轻量测试环境，无需 Ollama） ───
#  全部走通义千问 API，利用免费额度
LLM_CHAT_API_KEY=your_qwen_api_key_here
LLM_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_CHAT_MODEL=qwen-plus

LLM_TRIGGER_API_KEY=your_qwen_api_key_here
LLM_TRIGGER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TRIGGER_MODEL=qwen-turbo

LLM_MEMORY_API_KEY=your_qwen_api_key_here
LLM_MEMORY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MEMORY_MODEL=qwen-turbo

# ═══════════════════════════════════════════════════
#  上下文压缩
#
#  CONTEXT_MAX_TOKENS: 模型上下文窗口大小。
#    设为 0 时不启用压缩，回退到简单截断（默认）。
#    qwen-plus / qwen-turbo = 131072
#    本地 qwen2.5:7b (Ollama) ≈ 32768
#
#  COMPRESSION_STRATEGY: truncate（按轮截断）或 summary（LLM 摘要）。
#    summary 策略会调用 LLM_TRIGGER 端点进行摘要，消耗额外 token。
# ═══════════════════════════════════════════════════
# CONTEXT_MAX_TOKENS=131072
# COMPRESSION_THRESHOLD=0.82
# COMPRESSION_STRATEGY=truncate
# COMPRESSION_TRUNCATE_ROUNDS=1
# COMPRESSION_KEEP_RECENT=4
# COMPRESSION_SUMMARY_PROMPT=
